@page
@model Web.Pages.Productos.EliminarModel
@{
}

<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">SC-701</div>
        <div class="masthead-heading text-uppercase">Eliminar Producto</div>
    </div>
</header>

<section class="page-section bg-light">
    <div class="container">

        <div class="text-center">
            <h2>Eliminar Producto</h2>
            <h3 class="text-muted">¿Seguro que desea eliminar este producto?</h3>
        </div>

        <div class="col-md-6 mx-auto">
            <form method="post">

                <dl>

                    <dt>Nombre</dt>
                    <dd>@Model.producto.Nombre</dd>

                    <dt>Categoría</dt>
                    <dd>@Model.producto.Categoria</dd>

                    <dt>SubCategoría</dt>
                    <dd>@Model.producto.SubCategoria</dd>

                    <dt>Descripción</dt>
                    <dd>@Model.producto.Descripcion</dd>

                    <dt>Precio</dt>
                    <dd>₡ @Model.producto.Precio</dd>

                    <dt>Stock</dt>
                    <dd>@Model.producto.Stock</dd>

                    <dt>Código</dt>
                    <dd>@Model.producto.CodigoBarras</dd>

                </dl>

                <input type="hidden" asp-for="producto.Id" />

                <div class="form-group mt-3">
                    <a class="btn btn-primary" asp-page="./Index">Cancelar</a>
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </div>

            </form>
        </div>
    </div>
</section>